# --- Environment ---
.env
.env.local
.env.*.local

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.eggs/
.venv/
venv/
ENV/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
*.coverage.*

# --- Node / Electron ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/
.cache/
# package-lock.json is not committed — keeps the repo light and matches the
# existing convention. Re-generate locally with `npm install`.
package-lock.json

# Electron build artifacts (these used to be vendored in autogrok-veo3 but
# don't belong in source — electron-builder regenerates them).
desktop/dist-electron/
desktop/release/
desktop/out/
*.dll
*.dylib
*.so
*.pak
*.bin
*.dat
*.exe
*.app
*.ico
LICENSES.chromium.html
LICENSE.electron.txt

# --- Runtime / user data ---
electron-runtime.log
sessions/
output/
debug/
ref-images/
*.log
# Puppeteer userDataDir (Grok login session). Default location is inside
# `sessions/` above, but GROK_PROFILE_DIR may point this anywhere — also
# ignore the common opt-in name in case someone places it under desktop/.
grok-profile/
desktop/sessions/
desktop/grok-profile/
# Generation outputs when running in dev mode (BASE_DIR = desktop/).
desktop/images/
desktop/videos/
desktop/i2v-videos/
desktop/i2v-input/
desktop/logs/

# --- IDE / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
