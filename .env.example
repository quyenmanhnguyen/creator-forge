# --- Tube-Atlas research (Python sidecar) ---
# YouTube Data API v3 — https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# DeepSeek (Studio + Niche verdict + Cloner) — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Optional: override the sidecar port (default 5050)
CREATOR_FORGE_RESEARCH_PORT=5050

# Optional: pin the python interpreter the Electron sidecar uses
# CREATOR_FORGE_PYTHON=/path/to/.venv/bin/python

# --- AutoGrok (Electron desktop) ---
# Grok login is handled via Puppeteer the first time you use Image / Video /
# I2V / RefImage — sessions are persisted in the user-data folder. No keys here.

# Optional: pre-set user data dir (otherwise Electron uses the OS default)
# AUTOGROK_USER_DATA_DIR=/path/to/data

# Optional: persistent Puppeteer userDataDir for Grok login (overrides
# AUTOGROK_USER_DATA_DIR/sessions). Recommended outside the repo so
# cookies don't sit next to source code.
# GROK_PROFILE_DIR=/Users/me/.creator-forge/grok-profile

# Optional: explicit path to Chrome / Edge if auto-detect fails (rare).
# CHROME_EXECUTABLE_PATH=/usr/bin/google-chrome
