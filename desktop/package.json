{
  "name": "creator-forge",
  "productName": "Creator Forge",
  "version": "0.1.0",
  "description": "End-to-end YouTube creator suite — research, scriptwriting, AutoGrok image generation, and 9:16 mp4 compose. Electron desktop + Python FastAPI sidecar.",
  "author": {
    "name": "quyenmanhnguyen",
    "url": "https://github.com/quyenmanhnguyen"
  },
  "homepage": "https://github.com/quyenmanhnguyen/creator-forge",
  "repository": {
    "type": "git",
    "url": "https://github.com/quyenmanhnguyen/creator-forge.git"
  },
  "license": "MIT",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "prefetch:python:win": "node ../scripts/fetch-python-runtime.js --platform win32 --arch x64",
    "prefetch:python:linux": "node ../scripts/fetch-python-runtime.js --platform linux --arch x64",
    "prefetch:python:mac:x64": "node ../scripts/fetch-python-runtime.js --platform darwin --arch x64",
    "prefetch:python:mac:arm64": "node ../scripts/fetch-python-runtime.js --platform darwin --arch arm64",
    "prefetch:python:mac": "npm run prefetch:python:mac:x64 && npm run prefetch:python:mac:arm64",
    "dist:win": "npm run prefetch:python:win && electron-builder --win --x64",
    "dist:mac": "npm run prefetch:python:mac && electron-builder --mac --x64 --arm64",
    "dist:linux": "npm run prefetch:python:linux && electron-builder --linux --x64"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "puppeteer": "^24.2.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
